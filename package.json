{
  "name": "nightbot-queue-save",
  "version": "0.1.0",
  "description": "Persist the Nightbot song-request queue to a CSV file.",
  "type": "module",
  "engines": { "node": ">=20" },
  "files": [
    "src",
    "tsconfig.json",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "login": "tsx src/index.ts login",
    "watch": "tsx src/index.ts watch",
    "scrape": "tsx src/index.ts scrape",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "release": "bash scripts/make-release.sh"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
